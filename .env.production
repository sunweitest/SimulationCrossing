# LLM 提供者选择 (dashscope 或 deepseek)
LLM_PROVIDER=dashscope

# DashScope API (LLM_PROVIDER=dashscope 时必填)
DASHSCOPE_API_KEY=sk-your-key-here
SHUIHU_APP_ID=your-shuihu-app-id
SANGUO_APP_ID=your-sanguo-app-id
MINGDAI_APP_ID=your-mingdai-app-id
QINGDAI_APP_ID=your-qingdai-app-id

# DeepSeek API (LLM_PROVIDER=deepseek 时必填)
DEEPSEEK_API_KEY=your-deepseek-key-here

# JWT (生产环境请改成随机字符串)
SECRET_KEY=production-secret-change-me
