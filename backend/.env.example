# 数据库配置
DATABASE_URL=postgresql+asyncpg://postgres:mysecretpassword@localhost:5432/simulation_crossing
AUTO_CREATE_TABLES=false

# JWT配置
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Redis配置 (用于次数限制)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# LLM 提供者选择
LLM_PROVIDER=dashscope

# DashScope API配置（LLM_PROVIDER=dashscope 时必填）
DASHSCOPE_API_KEY=your-dashscope-api-key
SHUIHU_APP_ID=your-shuihu-app-id
SANGUO_APP_ID=your-sanguo-app-id
MINGDAI_APP_ID=your-mingdai-app-id
QINGDAI_APP_ID=your-qingdai-app-id
XIYOU_APP_ID=your-xiyou-app-id

# DeepSeek API配置（LLM_PROVIDER=deepseek 时必填）
DEEPSEEK_API_KEY=your-deepseek-api-key

# DeepSeek 模型参数（可选，以下为默认值）
DEEPSEEK_TEMPERATURE=0.8
DEEPSEEK_MAX_TOKENS=4096
DEEPSEEK_REASONING_EFFORT=high
DEEPSEEK_MAX_HISTORY_TURNS=8

# CORS配置
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# 次数限制配置
DAILY_FREE_MESSAGES=50
DAILY_LOGGED_IN_EXTRA=150

# 管理后台密钥
ADMIN_KEY=your-admin-key-change-me
